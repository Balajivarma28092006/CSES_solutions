#include <bits/stdc++.h>

using namespace std;

int main() {
    int n, m, k;
    cin >> n >> m >> k;

    vector<int> sizes;
    for(int i = 0; i < n; i++){
        cin >> sizes[i];
    }

    vector<int> bsizes;
    for(int i = 0; i < m; i++){
        cin >> bsizes[i];
    }
    int count;
    
    for(int i = 0; i < n;i++){
        for(int j = 0; j < m; j++){
            if(bsizes[j] >= sizes[i] - k && bsizes[j] <= sizes[i]){
                count++;
                bsizes[j] = -1;
                break;
            }
        }
    }
    cout << count << endl;
    return 0;
}
